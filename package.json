{
  "name": "chatgphish-sanitizer",
  "version": "1.0.0",
  "description": "Chrome extension for protection against XPIA (Cross-Site Prompt Injection) attacks on ChatGPT and other LLMs",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --config extension/vite.config.ts",
    "build": "vite build --config extension/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint extension/src/ tests/",
    "lint:fix": "eslint extension/src/ tests/ --fix",
    "format": "prettier --write \"extension/src/**/*.{ts,tsx,json,css}\" \"tests/**/*\"",
    "format:check": "prettier --check \"extension/src/**/*.{ts,tsx,json,css}\" \"tests/**/*\""
  },
  "keywords": [
    "chrome-extension",
    "security",
    "xss",
    "xpia",
    "chatgpt",
    "llm",
    "phishing-protection"
  ],
  "author": "ChatGPhish Sanitizer Team",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  },
  "dependencies": {
    "onnxruntime-web": "^1.19.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "chart.js": "^4.4.0"
  }
}
